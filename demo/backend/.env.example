# VRI MSME Credit Scoring — Environment Configuration
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS (comma-separated origins for frontend dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Anthropic (optional — enables Claude-powered reports)
# Without this, the system falls back to template-based reports
ANTHROPIC_API_KEY=

# App
APP_NAME=VRI MSME Credit Scoring System
